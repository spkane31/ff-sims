[Unit]
Description=ff-sims lifetime-counts cron job
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User={{SERVICE_USER}}
WorkingDirectory={{REPO_DIR}}/backend
EnvironmentFile=/etc/ff-sims-worker.env
# Type=oneshot services default to DefaultTimeoutStartSec (commonly 90s)
# before systemd kills them for "taking too long to start". This job now
# also does the archive replicate/purge work formerly run by its own
# Temporal schedule (up to a 4h budget there, but on a 6h cadence) — most
# hourly runs should finish in well under a minute once caught up, but the
# ceiling needs real headroom for the batches a slow/backlogged run might
# do. Mirrors how ff-sims-discovery budgets 50m inside a 55min
# TimeoutStartSec.
TimeoutStartSec=50min
ExecStart={{REPO_DIR}}/backend/cron -job=lifetime-counts -max-duration=45m
